# Static mockup (default): omit this file or use:
# VITE_USE_MOCK_API=true

# Live "Check endpoint" calls POST /api/contracts/live-check on Express (axios replay).
# Run the API: npm run dev:stack (or npm run dev --prefix server) alongside the Vite dev server.

# Full-stack local development (Express + Vite proxy):
# Copy to .env.development and run: npm run dev:stack  (from repo root)
# VITE_USE_MOCK_API=false
# VITE_API_URL=
# (empty VITE_API_URL = relative /api/* → Vite proxies to server — see vite.config.js)

# Production SPA talking to a hosted API:
# VITE_USE_MOCK_API=false
# VITE_API_URL=https://your-api.example.com
